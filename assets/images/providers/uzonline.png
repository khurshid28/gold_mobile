  $(document).ready(function () {
    let maxHeight = 0;

    new Swiper("#servicesSwiper", {
      navigation: {
        nextEl: ".mainPageServices-button-next",
        prevEl: ".mainPageServices-button-prev",
      },
      breakpoints: {
        320: {
          slidesPerView: 1.5,
          spaceBetween: 12,
        },
        767: {
          slidesPerView: 3,
          spaceBetween: 16,
        },
      },
    });

    const slides = $("#servicesSwiper").find(".swiper-slide");

    slides.each(function () {
      const slideHeight = $(this).height();
      if (slideHeight > maxHeight) maxHeight = slideHeight;
    });

    $(".serviceMainCard").each(function () {
      const h = $(this).height();
      if (h > maxHeight) maxHeight = h;
    });

    slides.css("height", `${maxHeight}px`);
  });
