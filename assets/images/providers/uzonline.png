border-2 border-gray300 my-[0!important] dark:bg-gray900 dark:border-gray700"> <p class="text-[12px] text-gray500 dark:text-gray400 leading-[12px]"> Telefon raqam </p> <div class="relative w-full flex items-center"> <span class="text-gray700 dark:text-gray200 text-[14px] md:text-[16px] leading-[16px]">
+998
</span> <input class="masked-input customInput bg-[transparent] text-[14px] md:text-[16px] leading-[16px] bg-transparent dark:text-gray200 text-gray700 w-full pl-1" type="tel" inputmode="tel" placeholder="XX XXX XX XX" id="phoneNumberMnp" required name="phone_number"> </div> <div class="correct-icon cursor-pointer flex items-center rounded-[8px] bg-[inherit] p-[15px] md:p-[20px] absolute right-[0] top-[50%] translate-y-[-50%] h-[46px] mdh-[52px] hidden"> <svg width="18" height="13" viewBox="0 0 18 13" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 1L6 12L1 7" stroke="#12B76A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </div> <div class="clear-icon cursor-pointer flex items-center rounded-[8px] bg-[inherit] p-[15px] md:p-[20px] absolute right-[0] top-[50%] translate-y-[-50%] h-[46px] md:h-[52px] hidden"> <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13 1L1 13M1 1L13 13" stroke="#98A2B3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </div> </div> <script>(function(){const maskPlaceholder = "X";

  $(".masked-input").inputmask({
    mask: "99 999 99 99",
    showMaskOnHover: false,
    placeholder: maskPlaceholder ?? "X",
  });

  $(".customInput").each(function (i, el) {
    $(el).on("input", onChangeInput);
    $(el).focus(onChangeInput);
  });

  function onChangeInput(e) {
    const parent = $(this).parent();
    const clearIcon = $(parent).children(".clear-icon");
    const correctIcon = $(parent).children(".correct-icon");

    if ($(this).attr("class").includes("mask")) {
      const val = $(this).val().replaceAll(" ", "");
      if ($(this).data("length") === val.length) {
        if (val.slice(1, 4) !== "998") addError(".error-1");
        else addCorrectIcon(".error-1");
      } else addClearIcon(".error-1");
    } else if ($(this).val().length > 0) {
      addCorrectIcon();
    } else {
      addClearIcon();
    }

    function addClearIcon(errClassName) {
      $(parent).css("border-color", "#2481EA");
      $(clearIcon).css("display", "flex");
      if (errClassName) $(parent).next(errClassName).css("display", "none");
      $(clearIcon).on("click", function () {
        $(this).siblings("input").val("");
        $(parent).css("border-color", "#D0D5DD");
        $(clearIcon).css("display", "none");
      });
    }

    function addCorrectIcon(errClassName) {
      $(parent).css("border-color", "#12B76A");
      $(clearIcon).css("display", "none");
      $(correctIcon).css("display", "flex");
      if (errClassName) $(parent).next(errClassName).css("display", "none");
    }

    function addError(errClassName) {
      $(parent).next(errClassName).css("display", "flex");
      $(parent).css("border-color", "red");
      $(clearIcon).css("display", "flex");
      $(correctIcon).css("display", "none");
    }
  }
})();</script> <button id="sendPhoneNumberMnp" class="rounded-[8px] h-[48px] md:h-[56px] bg-brand700 text-gray25 text-[16px] md:text-[20px] font-semibold">Kodni olish</button> </div> </div> <div class="hidden xl:block absolute bottom-[0] right-[20px] z-[1] w-[272px] h-[230px] bg-[url('/fixed/images/new/topServiceBannerBg2.webp')] bg-norepeat bg-cover"></div> </div> </div> <div class="cf-integrated-6"></div> </section> <script>(function(){const lang = "uz";
const links = {"en":{"mnp":"en/for-individuals/mobile-number-portability","onb":"en/for-individuals/online-booking-of-mobile-numbers"},"ru":{"mnp":"ru/chastnym-licam/perevod-mobilnogo-nomera","onb":"ru/chastnym-licam/onlayn-bronirovanie-mobilnyx-nomerov"},"uz":{"mnp":"uz/jismoniy-shaxslarga/mobil-raqamni-kochirish","onb":"uz/jismoniy-shaxslarga/mobil-raqamlarni-onlayn-band-qilish"}};

  $(document).ready(function () {
    const onbCode = $("#onbCode");

    $(".phone-number").keyup(function (e) {
      if (this.value.length > 1) this.value = this.value.slice(0, 1);
      if (e.keyCode === 8 || e.keyCode === 46 || e.keyCode === 37) {
        $(e.target).parent().prev().children().focus();
        return;
      }
      if ((e.keyCode !== 13 && e.target.value.length > 0) || e.keyCode === 39)
        $(e.target).parent().next().children().focus().select();
    });
    $(".phone-number").focus((e) => $(e.target).select());

    onbCode.find("button").on("click", function () {
      onbCode.find(".value").html($(this).html());
      onbCode.find("button").removeClass("text-brand600");
      $(this).addClass("text-brand600");
    });

    $("#sendPhoneNumberOnb").on("click", function () {
      let numbers = "";
      $(".phone-number").each(function () {
        const value = $(this).val();
        numbers += value.length ? value : "-";
      });

      window.location.href = `${window.location.origin}/${links[lang].onb}?phoneNumber=${onbCode.find(".value").html()}${numbers}`;
    });

    $("#sendPhoneNumberMnp").on("click", function () {
      window.location.href = `${window.location.origin}/${links[lang].mnp}?phoneNumber=${$("#phoneNumberMnp").val().replaceAll(" ", "").replaceAll("+", "")}`;
    });
  });
