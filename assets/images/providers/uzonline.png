s"> Kunu-tun 1009 ma’lumotlar xizmati   </p> <p class="text-gray500 text-[16px] dark:text-gray25 overflow-hidden text-ellipsis"> Kerakli telefon raqamlari, manzillar va boshqa ma’lumotlarni osonlikcha topish imkoniyati. </p> </div> <img src="https://minio.uzdc.uz/utc-new/Utc-prod/9b6d98dd-a94c-4e65-ac87-2a43f0a74d01/1009.svg" alt="nav icon" class="w-[64px] h-auto max-h-[80px] ml-auto"> </a> </div>   <div class="min-w-[252px] flex flex-col gap-[15px] py-[32px]"> <a href="/uz/jismoniy-shaxslarga/boshqa-xizmatlar/call-markaz-xizmatlari/tungi-ertaklar-va-bolalar-qoshiqlari" class="flex items-center gap-[8px]"> <div class="headerNavIcon w-[24px] h-[24px] relative" data-url="https://minio.uzdc.uz/utc-new/Utc-prod/924bcdf2-6eef-4234-83c0-13e7ebf37a2b/Skazka.svg"></div>  <p class="text-gray500 text-[16px] font-semibold dark:text-gray25"> Tungi ertaklar va bolalar qo‘shiqlari   </p> </a><a href="/uz/jismoniy-shaxslarga/boshqa-xizmatlar/call-markaz-xizmatlari/tabriklash" class="flex items-center gap-[8px]"> <div class="headerNavIcon w-[24px] h-[24px] relative" data-url="https://minio.uzdc.uz/utc-new/Utc-prod/4017d7b0-31e9-483d-96e6-b2f0c9cd3dcd/pozdrav.svg"></div>  <p class="text-gray500 text-[16px] font-semibold dark:text-gray25"> Tabriklash   </p> </a><a href="/uz/jismoniy-shaxslarga/boshqa-xizmatlar/call-markaz-xizmatlari/xabar-qilish" class="flex items-center gap-[8px]"> <div class="headerNavIcon w-[24px] h-[24px] relative" data-url="https://minio.uzdc.uz/utc-new/Utc-prod/23de7b6d-efa7-4b26-b3f3-165c5539e857/notification.svg"></div>  <p class="text-gray500 text-[16px] font-semibold dark:text-gray25"> Xabar qilish   </p> </a><a href="/uz/jismoniy-shaxslarga/boshqa-xizmatlar/call-markaz-xizmatlari/ob-havo-malumotlari" class="flex items-center gap-[8px]"> <div class="headerNavIcon w-[24px] h-[24px] relative" data-url="https://minio.uzdc.uz/utc-new/Utc-prod/70a82ce2-1007-4bb7-b82e-00b76d4cc2f8/pogoda.svg"></div>  <p class="text-gray500 text-[16px] font-semibold dark:text-gray25"> Ob-havo ma’lumotlari   </p> </a><a href="/uz/jismoniy-shaxslarga/boshqa-xizmatlar/call-markaz-xizmatlari/retseptlar" class="flex items-center gap-[8px]"> <div class="headerNavIcon w-[24px] h-[24px] relative" data-url="https://minio.uzdc.uz/utc-new/Utc-prod/edcec719-989e-405a-8307-0e7d0cb3c096/retsept.svg"></div>  <p class="text-gray500 text-[16px] font-semibold dark:text-gray25"> Retseptlar   </p> </a><a href="/uz/jismoniy-shaxslarga/boshqa-xizmatlar/call-markaz-xizmatlari/aniq-vaqt" class="flex items-center gap-[8px]"> <div class="headerNavIcon w-[24px] h-[24px] relative" data-url="https://minio.uzdc.uz/utc-new/Utc-prod/c200e7ee-5e12-45fd-9325-8f725b8dd355/clock.svg"></div>  <p class="text-gray500 text-[16px] font-semibold dark:text-gray25"> Аniq vaqt   </p> </a><a href="/uz/jismoniy-shaxslarga/boshqa-xizmatlar/call-markaz-xizmatlari/1064-xizmati" class="flex items-center gap-[8px]"> <div class="headerNavIcon w-[24px] h-[24px] relative" data-url="https://minio.uzdc.uz/utc-new/Utc-prod/9e67685b-cf0b-455f-9f9f-90f283d90a18/call center.svg"></div>  <p class="text-gray500 text-[16px] font-semibold dark:text-gray25"> 1064 xizmati   </p> </a><a href="/uz/jismoniy-shaxslarga/boshqa-xizmatlar/call-markaz-xizmatlari/1086-xizmati" class="flex items-center gap-[8px]"> <div class="headerNavIcon w-[24px] h-[24px] relative" data-url="https://minio.uzdc.uz/utc-new/Utc-prod/9e67685b-cf0b-455f-9f9f-90f283d90a18/call center.svg"></div>  <p class="text-gray500 text-[16px] font-semibold dark:text-gray25"> 1086 - xizmati   </p> </a> </div>  </div> </div> </div><div class="menuItem group h-[88px] flex items-center relative text-[16px] font-medium text-gray500 dark:text-gray400 dark:hover:text-gray25 hover:text-gray900 cursor-pointer"> <a href="/uz/kompaniya-haqida/faq-1"> FAQ   </a>  </div> </div> <script>
  $(document).ready(function () {
    try {
      var all = $(".headerNavIcon");
      all.each(async function () {
        const $this = $(this);
        const url = $this.data("url");
        if (url?.length) {
          var svg = await fetch(url);
          var text = await svg.text();
          text = text.toString();
          if (text.split("<path")[1].includes("fill="))
            text = text
              .toString()
              .replace("<path", "<path class='fill-gray500 dark:fill-gray300'");
          else if (text.split("<path")[1].includes("stroke="))
            text = text
              .toString()
              .replace(
                "<path",
                "<path class='stroke-gray500 dark:stroke-gray300'"
              );

          text = text.replace("<svg ", "<svg class='w-[24px] h-[24px]'");
          $this.html(text);
        }
      });
    } catch (error) {
      console.error("Error loading SVG:", error);
    }

    const headerLargeMenu = $("#headerLargeMenu");
    const headerLargeMenuItems = headerLargeMenu.find(".menuItem");
    const headerLargeShadow = $("#headerLargeShadow");

    headerLargeMenu.find(".menuItem").each(function () {
      let parent = $(this);
      var parentRect = parent[0].getBoundingClientRect();
      let childEl = parent.find(".tooltip");
      if (childEl.length) {
        let childRect = childEl[0].getBoundingClientRect();
        let windowWidth = $(window).width();
        if (childRect.left < 0)
          childEl.css("transform", "translateX(-" + parentRect.x + "px)");
        else if (childRect.right > windowWidth)
          childEl.css(
            "transform",
            "translateX(-" + (childRect.right - windowWidth + 48) + "px)"
          );
      }
    });

    if (headerLargeMenu.is(":hover")) {
      headerLargeShadow.removeClass("invisible opacity-0");
    }

    headerLargeMenuItems.hover(
      function onHoverHeaderItem() {
        if ($(this).children("div").length) {
          headerLargeShadow.removeClass("invisible opacity-0");
          document.body.style.overflow = "hidden";
          document.body.style.touchAction = "none";
        }
      },
      function onHoverHeaderItem() {
        headerLargeShadow.addClass("invisible opacity-0");
        document.body.style.overflow = "";
        document.body.style.touchAction = "";
      }
    );
  });
</script> <div class="flex items-center gap-[24px]"> <form id="searchForm" class="absolute overflow-hidden w-[0] right-[0] invisible opacity-0 bg-gray100 dark:bg-gray700 rounded-[8px] p-[16px] flex items-center gap-[20px] duration-300"> <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M19 19L14.65 14.65M17 9C17 13.4183 13.4183 17 9 17C4.58172 17 1 13.4183 1 9C1 4.58172 4.58172 1 9 1C13.4183 1 17 4.58172 17 9Z" class="stroke-gray800 dark:stroke-gray400" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> <input type="text" placeholder="Siz nimani izlayapsiz?" class="text-[16px] text-gray400 bg-[inherit] w-full"> <button type="button" id="closeSearch"> <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M0.292893 0.292893C0.683417 -0.0976311 1.31658 -0.0976311 1.70711 0.292893L7 5.58579L12.2929 0.292893C12.6834 -0.0976311 13.3166 -0.0976311 13.7071 0.292893C14.0976 0.683417 14.0976 1.31658 13.7071 1.70711L8.41421 7L13.7071 12.2929C14.0976 12.6834 14.0976 13.3166 13.7071 13.7071C13.3166 14.0976 12.6834 14.0976 12.2929 13.7071L7 8.41421L1.70711 13.7071C1.31658 14.0976 0.683417 14.0976 0.292893 13.7071C-0.0976311 13.3166 -0.0976311 12.6834 0.292893 12.2929L5.58579 7L0.292893 1.70711C-0.0976311 1.31658 -0.0976311 0.683417 0.292893 0.292893Z" fill="#98A2B3"></path></svg> </button> </form> <button id="openSearch"> <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M19 19L14.65 14.65M17 9C17 13.4183 13.4183 17 9 17C4.58172 17 1 13.4183 1 9C1 4.58172 4.58172 1 9 1C13.4183 1 17 4.58172 17 9Z" class="stroke-gray500 dark:stroke-gray400" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </button> <a href="https://cabinet.uztelecom.uz" class="rounded-[10px] dark:bg-brand600 bg-brand700 flex items-center text-[14px] text-white px-[1