ishlar munosabati bilan Toshkent shahri ATS-265/266 stansiyasida 2026-yil 24-aprel kuni (soat 00:00 dan 06:00 gacha) xizmatlar sifatini yaxshilashga qaratilgan ishlar olib boriladi. </p> </div> </div> <div class="mb-[25px] flex items-center justify-end z-[4] relative gap-[20px]"> <!-- md:translate-x-[60px] --> <button type="button" class="mainPageNews-button-prev group"> <svg width="20" height="9" viewBox="0 0 20 9" fill="none" class="" xmlns="http://www.w3.org/2000/svg"><path d="M19 1H1L7.15789 8" class="stroke-gray800 group-disabled:stroke-gray400 dark:stroke-gray400 dark:group-disabled:stroke-gray400 dark:group-disabled:opacity-[0.4]" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </button> <button type="button" class="mainPageNews-button-next group"> <svg width="20" height="9" viewBox="0 0 20 9" fill="none" class="" xmlns="http://www.w3.org/2000/svg"><path d="M1 1H19L12.8421 8" class="stroke-gray800 group-disabled:stroke-gray400 dark:stroke-gray400 dark:group-disabled:stroke-gray400 dark:group-disabled:opacity-[0.4]" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </button> </div> <div class="mainPageNewsSliderPagination flex items-center gap-[1px]"></div> </div> </div> </div> <div class="cf-integrated-11"></div> </section> <script>
  $(document).ready(function () {
    const newsTypeBtn = $(".newsTypeBtn");
    let currentFirstLink;
    const slides = $(".mainPageNewsSlider .swiper-slide");
    const firstLinkBtn = $("#watchAllFirst");
    let maxHeight = 0;

    slides.each(function () {
      var thisHeight = $(this).height();
      if (thisHeight > maxHeight) {
        maxHeight = thisHeight;
      }
    });

    slides.height(maxHeight);

    newsTypeBtn.on("click", function () {
      newsTypeBtn.removeClass("text-gray900 dark:text-gray25");
      newsTypeBtn.addClass("text-gray600 dark:text-gray400");
      $(this).addClass("text-gray900 dark:text-gray25");
      $(this).removeClass("text-gray600 dark:text-gray400");
      currentFirstLink = $(this).data("link");

      $("div[id^='newsSwiper']").addClass("hidden");

      $(`#newsSwiper${$(this).data("type")}`).removeClass("hidden");
    });

    firstLinkBtn.on("click", () => {
      window.location.href = `${window.location.origin}/${currentFirstLink ?? $(newsTypeBtn[0]).data("link")}`;
    });

    new Swiper(".mainPageNewsSlider", {
      slidesPerView: 1,
      spaceBetween: 24,
      loop: true,
      loopSlides: 0,
      pagination: {
        el: ".mainPageNewsSliderPagination",
      },
      navigation: {
        nextEl: ".mainPageNews-button-next",
        prevEl: ".mainPageNews-button-prev",
      },
    });
  });
</script> <div id="tariffModalUssd" class="invisible opacity-0 p-[20px] duration-100 fixed top-[50%] translate-y-[-50%] left-[50%] translate-x-[-50%] z-[10001] w-full h-screen flex items-center justify-center"> <div class="max-h-[90%] md:max-h-[initial] overflow-y-scroll bg-gray25 dark:bg-gray600 rounded-[32px] px-[24px] md:px-[47px] py-[40px] w-full max-w-[854px]"> <div class="flex items-center justify-between gap-[30px] mb-[32px]"> <h3 class="text-[24px] md:text-[36px] font-semibold text-gray900 dark:text-gray25"> Ulanish tarifi <span class="tariffName"></span> </h3> <button class="closeModal"> <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M0.292893 0.292893C0.683417 -0.0976311 1.31658 -0.0976311 1.70711 0.292893L7 5.58579L12.2929 0.292893C12.6834 -0.0976311 13.3166 -0.0976311 13.7071 0.292893C14.0976 0.683417 14.0976 1.31658 13.7071 1.70711L8.41421 7L13.7071 12.2929C14.0976 12.6834 14.0976 13.3166 13.7071 13.7071C13.3166 14.0976 12.6834 14.0976 12.2929 13.7071L7 8.41421L1.70711 13.7071C1.31658 14.0976 0.683417 14.0976 0.292893 13.7071C-0.0976311 13.3166 -0.0976311 12.6834 0.292893 12.2929L5.58579 7L0.292893 1.70711C-0.0976311 1.31658 -0.0976311 0.683417 0.292893 0.292893Z" fill="#98A2B3"></path></svg> </button> </div> <div class="flex gap-[20px] flex-col-reverse xl:flex-row items-start"> <div class="bg-white dark:bg-gray800 shadow-md px-[24px] py-[24px] flex items-center gap-[20px] w-full xl:max-w-[390px] rounded-[8px]"> <div class="w-[56px] h-[56px] flex items-center justify-center rounded-[16px] text-[24px] text-white font-semibold bg-gradient-to-t from-[#597DF8] to-[#A959F9]">
