p></a><a href="/uz/jismoniy-shaxslarga/boshqa-xizmatlar/call-markaz-xizmatlari/1086-xizmati" class="flex items-center gap-[8px] w-full"><div class="headerNavIcon w-[24px] h-[24px]" data-url="https://minio.uzdc.uz/utc-new/Utc-prod/9e67685b-cf0b-455f-9f9f-90f283d90a18/call center.svg"></div><p class="text-[14px] text-gray500 font-medium dark:text-gray400 text-ellipsis overflow-hidden">1086 - xizmati  </p></a></div></div></div><a href="/uz/kompaniya-haqida/faq-1" class="flex w-full items-center min-h-[72px] justify-between bg-white dark:bg-gray700 gap-[15px] p-[24px] rounded-[24px]"><p class="text-gray900 font-semibold text-[20px] overflow-hidden text-ellipsis dark:text-gray400">FAQ  </p><img alt="nav icon" class="w-[64px] h-auto ml-auto"></a> </div> <script>
  $(document).ready(function () {
    const border = $("#mobileTabBorder");
    const mobileTabs = $(".mobile-tab-item");
    const currentBorderTab = mobileTabs[window.currentTabIndex];
    const mobileTabWrapper = $("#mobileTabs");
    var scrollPosition =
      $(currentBorderTab).position().left + mobileTabWrapper.scrollLeft();

    window.changeBorderTab = function (el) {
      const elWidth = $(el).outerWidth();
      const elLeft = $(el).position().left;

      $(mobileTabs).removeClass("text-gray800 dark:text-gray25");
      $(mobileTabs).addClass("dark:text-gray400");
      $(el).removeClass("dark:text-gray400");
      $(el).addClass("text-gray800 dark:text-gray25");

      $(border).css({
        width: elWidth,
        left: elLeft,
      });
    };

    $(mobileTabs).on("click", function () {
      window.changeBorderTab(this);
      const scrollPosition =
        $(this).position().left + mobileTabWrapper.scrollLeft();
      mobileTabWrapper.animate({ scrollLeft: scrollPosition }, 500);
    });

    window.changeBorderTab(mobileTabs[window.currentTabIndex]);

    mobileTabWrapper.animate(
      {
        scrollLeft: scrollPosition,
      },
      300
    );
  });
