  $(document).ready(function () {
    if (window.innerWidth < 768) $(".footer-accordion").attr("disabled", false);
    const accordions = $(".footer-accordion");

    accordions.on("click", function () {
      const button = $(this);

      accordions.not(button).next().slideUp("slow");
      accordions.not(button).children("div").removeClass("rotate-90");

      button.next().stop(true, true).slideToggle("slow");
      button.children("div").toggleClass("rotate-90");
    });
  });
</script> <div id="bodyShadow" class="invisible opacity-0 duration-100 fixed top-[0] w-full h-screen z-[10000] bg-black50 dark:bg-black70"></div> <div id="headerLargeShadow" class="invisible opacity-0 backdrop-blur-[4px] duration-300 fixed top-[160px] w-full h-[calc(100vh_-_160px)] z-[10000] bg-black50 dark:bg-black70"></div> <div style="position:relative;z-index:1000;" id="omni-widget-root"> <script async data-locale="uz" src="https://omniwidget.uztelecom.uz/omni.widget.lib.js"></script> </div> </body> </html>