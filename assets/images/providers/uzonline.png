</div> </div> <div class="flex flex-col gap-[12px]"> <p class="text-[20px] font-medium text-gray600 dark:text-gray25"> Tarifni o&#39;zgartirish </p> <a href="https://cabinet.uztelecom.uz/" class="text-brand700 text-[20px] md:text-[24px] font-medium flex items-center gap-[10px] dark:text-gray25 dark:hover:underline"> <svg width="18" height="20" viewBox="0 0 18 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 19V17C17 15.9391 16.5786 14.9217 15.8284 14.1716C15.0783 13.4214 14.0609 13 13 13H5C3.93913 13 2.92172 13.4214 2.17157 14.1716C1.42143 14.9217 1 15.9391 1 17V19M13 5C13 7.20914 11.2091 9 9 9C6.79086 9 5 7.20914 5 5C5 2.79086 6.79086 1 9 1C11.2091 1 13 2.79086 13 5Z" class="stroke-brand700 dark:stroke-gray25" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> Shaxsiy kabinetda </a> </div> </div> </div> </div> </div> <div id="tariffModal" class="invisible opacity-0 p-[20px] duration-100 fixed top-[50%] translate-y-[-50%] left-[50%] translate-x-[-50%] z-[10001] w-full h-screen flex items-center justify-center"> <div class="max-h-[90%] overflow-y-scroll sm:overflow-y-hidden md:max-h-[initial] bg-gray25 dark:bg-gray600 rounded-[32px] px-[24px] md:px-[47px] py-[40px] w-full max-w-[1153px]"> <div class="flex items-center justify-between gap-[30px] mb-[32px]"> <h3 class="text-[24px] md:text-[36px] font-semibold text-gray900 dark:text-gray25"> Ulanish tarifi <span class="tariffName"></span> </h3> <button class="closeModal"> <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M0.292893 0.292893C0.683417 -0.0976311 1.31658 -0.0976311 1.70711 0.292893L7 5.58579L12.2929 0.292893C12.6834 -0.0976311 13.3166 -0.0976311 13.7071 0.292893C14.0976 0.683417 14.0976 1.31658 13.7071 1.70711L8.41421 7L13.7071 12.2929C14.0976 12.6834 14.0976 13.3166 13.7071 13.7071C13.3166 14.0976 12.6834 14.0976 12.2929 13.7071L7 8.41421L1.70711 13.7071C1.31658 14.0976 0.683417 14.0976 0.292893 13.7071C-0.0976311 13.3166 -0.0976311 12.6834 0.292893 12.2929L5.58579 7L0.292893 1.70711C-0.0976311 1.31658 -0.0976311 0.683417 0.292893 0.292893Z" fill="#98A2B3"></path></svg> </button> </div> <div class="flex gap-[20px] flex-col-reverse xl:flex-row items-end"> <div class="w-full flex flex-col gap-[16px]"> <p class="text-[16px] text-gray900 dark:text-gray25">UZTELECOM abonentlari uchun</p> <a href="https://utc.uz/app" class="bg-white dark:bg-gray800 shadow-md px-[24px] py-[24px] rounded-[8px] cursor-pointer"> <div class="w-[56px] h-[56px] flex items-center justify-center rounded-[16px] text-[24px] text-white font-semibold bg-gradient-to-t from-[#597DF8] to-[#59C6F9]"> <div class="w-[18px] flex flex-wrap justify-between items-center gap-[2px]"> <div class="w-[8px] h-[8px] border-2 border-white rounded-[1px]"></div> <div class="w-[8px] h-[8px] border-2 border-white rounded-[1px]"></div> <div class="w-[8px] h-[8px] border-2 border-white rounded-[1px]"></div> <div class="w-[8px] h-[8px] border-2 border-white rounded-[1px]"></div> </div> </div> <p class="mt-[32px] text-[24px] text-gray900 dark:text-gray25 font-semibold"> Ilova orqali ulaning </p> </a> </div> <div class="w-full flex flex-col gap-[16px]"> <p class="text-[16px] text-gray900 dark:text-gray25">Agar siz UZTELECOM abonenti <b>bo‘lmasangiz</b></p> <div id="tariffSendOrder" class="bg-white dark:bg-gray800 shadow-md px-[24px] py-[24px] rounded-[8px] cursor-pointer"> <div class="w-[56px] h-[56px] flex items-center justify-center rounded-[16px] text-[24px] text-white font-semibold bg-gradient-to-t from-[#597DF8] to-[#59C6F9]">
#
</div> <p class="mt-[32px] text-[24px] text-gray900 dark:text-gray25 font-semibold"> Ulanish uchun ariza yuboring </p> </div> </div> </div> </div> </div> <script>
  $(document).ready(function () {
    const sendBtn = $("#tariffSendOrder");
    const onbUrls = {
      en: "en/for-individuals/online-booking-of-mobile-numbers",
      ru: "ru/chastnym-licam/onlayn-bronirovanie-mobilnyx-nomerov",
      uz: "uz/jismoniy-shaxslarga/mobil-raqamlarni-onlayn-band-qilish",
    };
    const wiredUrls = {
      en: "en/general/online-order/internet-service-connection",
      ru: "ru/obshhee/onlayn-zayavka/podklyuchenie-k-internet-servisu",
      uz: "uz/umumiy/onlayn-ariza/internet-xizmatiga-ulanish",
    };
    const ipTelephonyUrls = {
      en: "en/ip-telephony",
      ru: "ru/ip-telefoniya",
      uz: "uz/ip-telefoniya",
    };

    sendBtn.on("click", function () {
      const lang = $(this).data("lang");
      const type = $(this).data("type");
      if (type === "GSM") {
        let redirectUrl = `${window.location.origin}/${onbUrls[lang]}?tariffId=${$(this).data("tariff")}`;
        let turnedOn = [];

        turnedOn.map(function (el, i) {
          redirectUrl += `&tariffServiceIds=${$(el).data("id")}`;
        });

        window.location.replace(redirectUrl);
      } else if (type === "INTERNET") {
        let redirectUrl = `${window.location.origin}/${wiredUrls[lang]}`;
        window.location.replace(redirectUrl);
      } else if (type === "IP_TELEPHONY") {
        let redirectUrl = `${window.location.origin}/${ipTelephonyUrls[lang]}`;
        window.location.replace(redirectUrl);
      }
    });
  });
