  $(document).ready(function () {
    const bgTab = $("#bgTab");
    const tabs = $(".tab-item");

    window.currentTabIndex = currentTabIndex == -1 ? 0 : currentTabIndex;
    window.changeTab = function (el) {
      const elWidth = $(el).outerWidth();
      const elLeft = $(el).position().left;

      $(tabs).addClass("dark:text-gray400");
      $(tabs).removeClass("text-gray800 dark:text-gray25imp");
      $(el).addClass("text-gray800 dark:text-gray25imp");
      $(el).removeClass("dark:text-gray400");

      $(bgTab).css({
        width: elWidth,
        left: elLeft,
      });
    };

    $(tabs).on("click", function () {
      window.changeTab(this);
    });

    window.changeTab(tabs[window.currentTabIndex]);
