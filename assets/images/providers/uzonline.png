            <a href="/uz/jismoniy-shaxslarga/internet/tariflar/hammasi-birga/hammasi-birga-4" data-name="Hammasi birga 4" data-tariff="4534" class="detailsTariff text-center block dark:text-brand600 text-brand700 mx-auto text-[16px] font-semibold"> Ko&#39;proq </a> </div> </div> <div class="absolute top-[100%] left-[50%] translate-x-[-50%] h-[32px] w-[calc(100%_-_100px)] flex items-center justify-center bg-yellow uppercase font-bold text-[16px] text-gray800 rounded-b-[8px] hidden"> Hit </div> </div><div class="swiper-slide min-h-[515px] " data-category="internet" style=""> <div class="p-[24px] bg-white dark:bg-gray800 shadow-lg rounded-[16px] md:rounded-[24px] lg:rounded-[32px] h-[100%] flex flex-col justify-between"> <div class="py-[16px] flex flex-col gap-[16px]"> <h3 class="text-[32px] font-medium text-gray900 dark:text-gray25"> Hammasi birga 3+ </h3> <!-- <p class="dark:text-brand600 text-brand700 mt-[5px] mb-[35px]">{type}</p> --> <div class="flex flex-col gap-[8px]"> <div class="flex items-center gap-[10px]"> <div class="w-[24px]"> <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16.0115 2.34501C14.4893 1.4615 12.76 0.997401 11 1.00001C5.477 1.00001 1 5.47701 1 11C1 16.523 5.477 21 11 21C16.523 21 21 16.523 21 11C21 9.18651 20.517 7.48501 19.673 6.01901" stroke="#0066DB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><path d="M14.975 7.02502C14.975 7.02502 13.281 11.5475 12.5 12.3285C12.1249 12.7036 11.6162 12.9143 11.0857 12.9143C10.5553 12.9143 10.0466 12.7036 9.6715 12.3285C9.29641 11.9534 9.08569 11.4447 9.08569 10.9143C9.08569 10.3838 9.29641 9.87511 9.6715 9.50002C10.4525 8.71902 14.975 7.02502 14.975 7.02502Z" stroke-width="2" stroke-linejoin="round" class="stroke-brand700 dark:stroke-brand600"></path></svg> </div> <div class="flex-1">  <p class="text-[14px] text-gray400">Internetga ulanish tezligi</p> <p class="text-[20px] text-gray900 dark:text-gray25 font-medium"> 350 Mbi