-y-[-50%] xl:w-[944px] xl:max-w-[initial] xl:h-[712px]"> <img src="/fixed/images/new/ourAppsShadow.webp" class="w-full h-auto"> </div> <div class="appBg1 px-[24px] md:px-[0] ourAppBg absolute w-full max-w-[382px] h-[287px] md:max-w-[670px] md:h-[506px] xl:w-[830px] xl:max-w-[initial] xl:h-[512px]"> <img src="" class="w-full h-auto"> </div> <div class="appBg2 px-[24px] md:px-[0] ourAppBg absolute w-full max-w-[382px] h-[287px] md:max-w-[670px] md:h-[506px] xl:w-[830px] xl:max-w-[initial] xl:h-[512px] hidden"> <img src="/fixed/images/new/ourAppsBg2.webp" class="w-full h-auto"> </div> <div class="appBg3 px-[24px] md:px-[0] ourAppBg absolute w-full max-w-[382px] h-[287px] md:max-w-[670px] md:h-[506px] xl:w-[830px] xl:max-w-[initial] xl:h-[512px] hidden"> <img src="/fixed/images/new/ourAppsBg3.webp" class="w-full h-auto"> </div> <div class="appBg4 px-[24px] md:px-[0] ourAppBg absolute w-full max-w-[382px] h-[287px] md:max-w-[670px] md:h-[506px] xl:w-[830px] xl:max-w-[initial] xl:h-[512px] hidden"> <img src="" class="w-full h-auto"> </div> <div class="ourAppCircle1 absolute w-[30px] h-[30px] md:w-[60px] md:h-[60px] xl:w-[72px] xl:h-[72px]"> <img src="/fixed/images/new/ourAppsCircle1.webp" class="w-full h-auto"> </div> <div class="ourAppCircle2 absolute w-[40px] h-[40px] md:w-[85px] md:h-[81px] xl:w-[113px] xl:h-[113px]"> <img src="/fixed/images/new/ourAppsCircle2.webp" class="w-full h-auto"> </div> <div class="ourAppCircle3 absolute w-[85px] h-[81px] md:w-[165px] md:h-[161px] xl:w-[223px] xl:h-[219px]"> <img src="/fixed/images/new/ourAppsCircle3.webp" class="w-full h-auto"> </div> </div> </section> <div class="cf-integrated-8"></div> <script>(function(){const ourAppsLinks = {"utcAppStore":"https://apps.apple.com/ru/app/myuztelecom/id1440173415","utcPlayMarket":"https://play.google.com/store/apps/details?id=uz.uztelecom.telecom&hl=ru&gl=US","utcAppGallery":"https://appgallery.huawei.com/app/C109301137","telecomTvPlayMarket":"https://play.google.com/store/apps/details?id=uz.telecom.telecomtv&hl=ru&gl","telecomTvAppStore":"https://apps.apple.com/us/app/telecomtv-uz-tv-online/id1661419958","telecomTvAppGallery":"https://appgallery.huawei.com/app/C108016275","utcBotPersonalCabinet":"https://t.me/utc_uzbot","utcBotChatBot":"https://t.me/uztelecomchatbot","myUzbekistanPlayMarket":"https://play.google.com/store/apps/details?id=uz.travel.my.uzb","myUzbekistanAppStore":"https://apps.apple.com/uz/app/myuzbekistan/id6744429545"};

  $(document).ready(function () {
    const wrapperLogo = $(".appWrapperLogo");
    const ourAppLink = $(".ourAppLink");
    const apps = $(".apps");
    const target = $("body")[0];

    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (
          mutation.type === "attributes" &&
          mutation.attributeName === "data-mode"
        ) {
          const newMode = $("body").attr("data-mode");

          if (newMode == "dark") {
            $(".appBg1 img").attr(
              "src",
              "/fixed/images/new/ourAppsBg1-dark.webp",
            );
            $(".appBg4 img").attr(
              "src",
              "/fixed/images/new/ourAppsBg4-dark.png",
            );
          } else {
            $(".appBg1 img").attr("src", "/fixed/images/new/ourAppsBg1.webp");
            $(".appBg4 img").attr("src", "/fixed/images/new/ourAppsBg4.png");
          }
        }
      });
    });

    const newMode = $("body").attr("data-mode");

    if (newMode == "dark") {
      $(".appBg1 img").attr("src", "/fixed/images/new/ourAppsBg1-dark.webp");
      $(".appBg4 img").attr("src", "/fixed/images/new/ourAppsBg4-dark.png");
    } else {
      $(".appBg1 img").attr("src", "/fixed/images/new/ourAppsBg1.webp");
      $(".appBg4 img").attr("src", "/fixed/images/new/ourAppsBg4.png");
    }

    observer.observe(target, { attributes: true });

    $(".appBtn").on("click", function () {
      const button = $(this);
      const index = button.data("index");
      var buttonPosition = button.position();
      var buttonLeft = buttonPosition.left;
      var newLeft = buttonLeft - (window.innerWidth > 640 ? 30 : 25);

      wrapperLogo.css("left", newLeft + "px");
      $(".apps [class^='app']").stop(true, true).slideUp();
      $(`.app${index}`).stop(true, true).slideDown();
      $("[class^='appBg']").addClass("hidden");
      $(`.appBg${index}`).removeClass("hidden");
      ourAppLink.attr("href", ourAppsLinks[index]);

      if (index == 1) {
        $(apps).addClass("rounded-tl-[0!important]");
        $(apps).removeClass("rounded-tr-[0!important] pr-[24px]");
      } else if (index == 2)
        $(apps).removeClass(
          "rounded-tl-[0!important] rounded-tr-[0!important] pr-[24px]",
        );
      else if (index == 4) {
        $(apps).addClass("rounded-tr-[0!important]");
        $(apps).removeClass("rounded-tl-[0!important] pr-[24px]");
      } else {
        $(apps).removeClass("rounded-tl-[0!important]");
        if (window.innerWidth <= 380 && window.innerWidth >= 368)
          button.parent().parent().addClass("pr-[0px]");
        else if (window.innerWidth <= 367)
          $(apps).addClass("rounded-tr-[0!important]");
        else button.parent().parent().removeClass("pr-[0px]");
      }
    });
  });
})();</script> <section class="py-[40px] md:py-[50px] lg:py-[75px]"> <div class="container px-[24px] gap-[24px] md:px-[48px] 2xl:px-[0] flex flex-col xl:flex-row items-stretch"> <a href="/uz/jismoniy-shaxslarga/mobil-aloqa/gsm/xizmatlar/rouming" class="flex-1 rounded-[16px] md:rounded-[24px] lg:rounded-[32px] dark:bg-gray800 bg-gray100 py-[20px] px-[16px] md:py-[40px] md:px-[32px] xl:py-[46px] xl:px-[48px]"> <div class="relative z-[3]"> <h3 class="text-[24px] md:text-[36px] font-bold text-gray900 dark:text-white"> Chegarasiz aloqa – qulay rouming tariflari! </h3> </div> <div class="flex justify-end"> <img class="w-[249px] h-[249px]" src="/fixed/images/new/paymentRoumingBg.webp" alt=""> </div> </a> <div class="xl:w-1/2 flex items-center justify-center" id="payment"> <!-- <iframe
