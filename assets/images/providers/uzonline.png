ma","singleCountDiscountPrice":"Chegirmali narx","chooseTariffWhichUsefulForYou":"O'zingiz uchun qulay tarifni yig'ib oling","chooseInternetTariffForYourHome":"Uy internetingiz uchun tarifni tanlang","chooseSimEsimCount":"SIM/eSIM sonini tanlang","choose":"Tanlash","chooseInternetTariffForHome":"Uy internet tarifni tanlash","chooseTariffForYourSimEsim":"SIM/eSIM kartangiz uchun tarifni tanlang","singleCountSimEsimPlaceholder":"SIM/eSIM","forConnectionChoseTariffRequestToSaleOffice":"Tanlangan tarif rejaga ulanish uchun Sotuv va xizmat ko‘rsatish ofisiga murojaat qiling","salesOfficesLocations":"Sotuv ofislari joylashuvi","chooseHomeInternetTariffAndChooseCountSimEsimFields":"Uy internet tarifini tanlang. Sim/eSim sonini tanlang va tanlangan Sim/eSim maydonlarini to'ldiring","topNews":"So'nggi yangiliklar","topRelationships":"So'nggi munosabatlar","topPromotions":"So'nggi aksiyalar","topNotifications":"So'nggi xabarnomalar","categories":"Kategoriyalar","latestDate":"Eng so'nggi","selectDate":"E'lon sanasini tanlang","notifications":"Xabarnomalar","promotions":"Aksiyalar","date_of_birth":"Tug'ilgan sana","passport_series_and_number":"Pasport seriyasi va raqami","type_of_convertible":"Murojaat qiluvchi turi","legal_person":"Yuridik shaxs","individual":"Jismoniy shaxs","patronymic":"Otasining ismi","firstname":"Ismi","lastname":"Familiyasi","chooseArea":"Viloyatni tanlang","enterValidName":"Ismingizni kiriting","enterValidLastName":"Familiyangizni kiriting","enterValidPatronymic":"Otasining ismini kiriting","enterValidEmail":"Emailni kiriting","enterValidPhone":"Telefon raqamini kiriting","enterValidDate":"Sanani kiriting","enterValidPassport":"Pasport ma'lumotlarini kiriting","enterAddress":"Manzilni kiriting","invalidPassport":"Noto'g'ri pasport","invalidPhone":"Noto'g'ri telefon","invalidPersonType":"Noto'g'ri murojaat qiluvchi turi","enterMessage":"Xabarni kiriting","chooseType":"Murojaat turini tanlang","choosePersonType":"Murojaatchi turini tanlang","chooseDistrict":"Tumanni tanlang","close":"Yopish","formConfirm":"Kiritilgan ma'lumotlar to'liq va to'g'riligini tasdiqlayman"};

  $(document).ready(function () {
    fetch(
      `${UtcUrl.VISIBILITY_CHECKBOX}/${VisibilityCheckboxTypes.IsShowTechnicalWorkWarning}`
    )
      .then((r) => r.json())
      .then((visibilityTechnicalWork) => {
        if (visibilityTechnicalWork?.is_show_technical_work_warning) {
          $("header").prepend(`
          <div class="technical-work">
            <p class="dark:text-white">${L.technicalWorkOnSite}</p>
          </div>
        `);

          let mm = gsap.matchMedia();

          mm.add("(min-width: 1400px)", () => {
            gsap.fromTo(
              ".technical-work p",
              { xPercent: -1 },
              { xPercent: 100, repeat: -1, duration: 30, ease: "linear" }
            );
          });
          mm.add("(min-width: 1200px)", () => {
            gsap.fromTo(
              ".technical-work p",
              { xPercent: -1 },
              { xPercent: 100, repeat: -1, duration: 25, ease: "linear" }
            );
          });
          mm.add("(min-width: 768px)", () => {
            gsap.fromTo(
              ".technical-work p",
              { xPercent: -30 },
              { xPercent: 100, repeat: -1, duration: 20, ease: "linear" }
            );
          });
          mm.add("(max-width: 767px)", () => {
            gsap.fromTo(
              ".technical-work p",
              { xPercent: -80 },
              { xPercent: 100, repeat: -1, duration: 15, ease: "linear" }
            );
          });
          mm.add("(max-width: 992px)", () => {
            $(".breadcrumbs").css("margin-top", "98px");
          });
        }
      });
    let isVoice = false;
    const tabs = $(".tab-item");
    const tariffCategory = $(".tariff-category");
    const mobileTabs = $(".mobile-tab-item");
    const dark = $(".darkBlock");
    const light = $(".lightBlock");
    const headerMobileMenu = $("#headerMobileMenu");
    const searchFormHeader = $("#searchForm");
    const searchFormHeaderMobile = $("#searchFormMobile");
    const langOptions = $(".langSelect a");
    const selectedItemsForEyeOption = $(
      "a, p, strong, span, address, h2, h4, h5, h6"
    );
    const btnChangeFontSize = $(".changeFontSize");

    selectedItemsForEyeOption.each(function () {
      const $this = $(this);
      $this.data("orig-size", $this.css("font-size"));
    });

    btnChangeFontSize.on("click", () => {
      const isActive = !btnChangeFontSize.data("active");

      btnChangeFontSize.children(".disactivated").toggleClass("hidden");
      btnChangeFontSize.children(".activated").toggleClass("hidden");

      btnChangeFontSize.data("active", isActive);
      selectedItemsForEyeOption.each(function () {
        const itemThis = $(this);
        const currentFontSize = +itemThis.css("font-size").split("px")[0] + 5;
        if (isActive) itemThis.css("font-size", currentFontSize + "px");
        else itemThis.css("font-size", itemThis.data("orig-size"));
      });

      setTimeout(() => {
        window.changeTab(tabs[window.currentTabIndex]);
        window.changeBorderTab(mobileTabs[window.currentTabIndex]);
        $(tariffCategory[0]).click();
        console.log(mobileTabs[window.currentTabIndex]);
      }, 200);
    });

    if ("theme" in localStorage) {
      if (localStorage.theme === "dark") toggleTheme(true);
      else toggleTheme(false);
    } else
      toggleTheme(window.matchMedia("(prefers-color-scheme: dark)").matches);

    dark.on("click", () => toggleTheme(true));

    light.on("click", () => toggleTheme(false));

    $("#openSearch").on("click", () => {
      $("#searchForm").removeClass("invisible visible opacity-0 w-[0]");
      $("#searchForm").addClass("visible opacity-1 w-full");
    });

    $("#closeSearch").on("click", () => {
      $("#searchForm").addClass("invisible visible opacity-0 w-[0]");
      $("#searchForm").removeClass("visible opacity-1 w-full");
      $("#searchForm input").val("");
    });

    $("#openHeaderMenu").on("click", () => {
      headerMobileMenu.addClass("right-[0]");
      headerMobileMenu.removeClass("right-[-100%]");
      $("#bodyShadow").toggleClass("invisible opacity-0");
    });

    $("#closeHeaderMenu").on("click", () => {
      headerMobileMenu.removeClass("right-[0]");
      headerMobileMenu.addClass("right-[-100%]");
      $("#bodyShadow").toggleClass("invisible opacity-0");
    });

    $(".openMobileWindow").on("click", () => {
      window.open(
        window.location.href,
        "_blank",
        "toolbar=yes, location=yes, directories=no, status=no, menubar=yes, scrollbars=yes, resizable=no, copyhistory=yes, width=375, height=400"
      );
    });

    $(".voiceEl").on("click", function () {
      $(this).children(".disactivated").toggleClass("hidden");
      $(this).children(".activated").toggleClass("hidden");
      isVoice = !isVoice;
    });

    searchFormHeader.on("submit", (e) => onSubmit(e));
    searchFormHeaderMobile.on("submit", (e) => onSubmit(e, true));

    window.onmouseup = drawBorderAroundSelection;

    langOptions.on("click", function (e) {
      e.preventDefault();
      window.location.replace($(this).attr("href") + window.location.hash);
    });

    function toggleTheme(isDark) {
      if (isDark) {
        localStorage.theme = "dark";
        $("body").attr("data-mode", "dark");
        dark.addClass("hidden");
        dark.removeClass("block");
        light.addClass("block");
        light.removeClass("hidden");
      } else {
        localStorage.theme = "light";
        $("body").attr("data-mode", "light");
        dark.addClass("block");
        dark.removeClass("hidden");
        light.addClass("hidden");
        light.removeClass("block");
      }
    }

    function drawBorderAroundSelection(e) {
      if (e.target.parentNode.className != "voice") {
        $(".rect").remove();
      }
      var selection = window.getSelection();
      if (selection.anchorNode && selection.anchorNode.nodeName == "#text") {
        range = selection.getRangeAt(0);
        rect = range.getBoundingClientRect();
        if (rect.width > 0 && window.getSelection().toString().length > 2) {
          window.selectedvoicetext = window.getSelection().toString();
          if (isVoice) {
            responsiveVoice.cancel();
            responsiveVoice.speak(window.selectedvoicetext, "Russian Female");
          }
        }
      }
    }

    function onSubmit(e, isMobile = false) {
      e.preventDefault();
      const text = isMobile
        ? searchFormHeaderMobile.children("input").val()
        : searchFormHeader.children("input").val();
      const path = window.location.pathname.split("/")[1];
      const locale = path.length == 2 ? path : "uz";
      window.location.href =
        window.location.origin +
        `/${locale}/search?query=${text}&locale=${locale}`;
    }

    function onClickLink(e) {
      const href = $(this).attr("href").split("#");
      if (
        href?.length > 1 &&
        !href[0].includes("http") &&
        href[0] === window.location.pathname
      ) {
        e.preventDefault();
        window.location.href = `${window.origin}${href[0]}#${href[1]}`;
        window.location.reload();
      }
    }

    $("header a").each(function () {
      $(this).on("click", onClickLink);
    });
    $("#headerMobileMenu a").each(function () {
      $(this).on("click", onClickLink);
    });
  });
})();</script>  <section class="pt-[24px] pb-[40px] md:pb-[50px] lg:pb-[75px]"> <div class="cf-integrated-1"></div> <div class="container px-[24px] md:px-[48px] 2xl:px-[0] relative"> <div id="previewSlider"> <div class="swiper-wrapper overflow-hidden h-[326px] md:h-[438px] xl:h-[378px] rounded-[16px] md:rounded-[24px] xl:rounded-[36px]"> <div data-url="e5742b5b-c15d-456c-8e09-be58a6a6bac0/1360х378px.jpg" class="swiper-slide bg-gray700 rounded-[inherit] p-[16px] md:p-[40px] bg-cover bg-center bg-no-repeat w-[100%] h-[inherit] text-left flex flex-col gap-[16px] md:gap-[24px]"> <h1 class="line-clamp-3 text-[24px] md:text-[32px] xl:text-[40px]  font-bold lg:max-w-[50%] leading-[29px] md:leading-[38px] lg:leading-[56px] text-gray25"> Farzand </h1> <p class="text-[14px] leading-[18px] md:text-[24px] text-gray25 lg:max-w-[50%] xl:leading-[32px]"> Farzandlarimiz uchun birinchi xavfsiz tarif </p> <a href="https://uztelecom.uz/uz/jismoniy-shaxslarga/mobil-aloqa/gsm/tariflar/imtiyozli-1/farzand" target="_self"> <div class="h-[40px] md:h-[56px] inline-flex bg-bluelight400 md:bg-[rgba(252,_252,_253,_0.1)] backdrop-blur-sm md:border px-[30px] rounded-[8px] text-gray25 border-gray25 text-[14px] md:text-[16px] xl:text-[18px] items-center gap-[10px]"> Batafsil </div> </a> </div><div data-url="c11bc632-1182-4221-9d0f-5a229b34cf94/Group 2087327739 (1).png" data-url-mobile="c2dbb77a-c090-47d3-af4c-37eb3d9d5009/382x326.png" class="swiper-slide bg-gray700 rounded-[inherit] p-[16px] md:p-[40px] bg-cover bg-center bg-no-repeat w-[100%] h-[inherit] text-left flex flex-col gap-[16px] md:gap-[24px]"> <h1 class="line-clamp-3 text-[24px] md:text-[32px] xl:text-[40px]  font-bold lg:max-w-[50%] leading-[29px] md:leading-[38px] lg:leading-[56px] text-gray25"> MyUZBEKISTAN </h1> <p class="text-[14px] leading-[18px] md:text-[24px] text-gray25 lg:max-w-[50%] xl:leading-[32px]"> Sayohatni osonlashtiradi </p> <a href="https://uztelecom.uz/uz/jismoniy-shaxslarga/myuzbekistan-1" target="_self"> <div clas