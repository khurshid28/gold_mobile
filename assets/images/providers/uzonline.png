ga 3+" data-code="1" data-label="1" data-lang="uz" data-tariff="10024" data-type="INTERNET" class="connectTariff h-[48px] dark:bg-brand600 bg-brand700 w-full rounded-[8px] text-[16px] text-white font-semibold mb-[10px]"> Ulanish </button>
            <a href="/uz/jismoniy-shaxslarga/internet/tariflar/hammasi-birga/hammasi-birga-3-plus" data-name="Hammasi birga 3+" data-tariff="10024" class="detailsTariff text-center block dark:text-brand600 text-brand700 mx-auto text-[16px] font-semibold"> Ko&#39;proq </a> </div> </div> <div class="absolute top-[100%] left-[50%] translate-x-[-50%] h-[32px] w-[calc(100%_-_100px)] flex items-center justify-center bg-yellow uppercase font-bold text-[16px] text-gray800 rounded-b-[8px] hidden"> Hit </div> </div><div class="swiper-slide min-h-[515px] " data-category="phone" style=""> <div class="p-[24px] bg-white dark:bg-gray800 shadow-lg rounded-[16px] md:rounded-[24px] lg:rounded-[32px] h-[100%] flex flex-col justify-between"> <div class="py-[16px] flex flex-col gap-[16px]"> <h3 class="text-[32px] font-medium text-gray900 dark:text-gray25"> Limitsiz </h3> <!-- <p class="dark:text-brand600 text-brand700 mt-[5px] mb-[35px]">{type}</p> --> <div class="flex flex-col gap-[8px]">  <div class="flex items-center gap-[10px]"> <div class="w-[24px]"> <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15.0504 5C16.0272 5.19057 16.9248 5.66826 17.6285 6.37194C18.3322 7.07561 18.8099 7.97326 19.0004 8.95M15.0504 1C17.0797 1.22544 18.972 2.13417 20.4167 3.57701C21.8613 5.01984 22.7724 6.91101 23.0004 8.94M22.0004 16.92V19.92C22.0016 20.1985 21.9445 20.4742 21.8329 20.7293C21.7214 20.9845 21.5577 21.2136 21.3525 21.4019C21.1473 21.5901 20.905 21.7335 20.6412 21.8227C20.3773 21.9119 20.0978 21.9451 19.8204 21.92C16.7433 21.5856 13.7874 20.5341 11.1904 18.85C8.77425 17.3147 6.72576 15.2662 5.19042 12.85C3.5004 10.2412 2.44866 7.27099 2.12042 4.18C2.09543 3.90347 2.1283 3.62476 2.21692 3.36162C2.30555 3.09849 2.44799 2.85669 2.63519 2.65162C2.82238 2.44655 3.05023 2.28271 3.30421 2.17052C3.5582 2.05833 3.83276 2.00026 4.11042 2H7.11042C7.59573 1.99522 8.06621 2.16708 8.43418 2.48353C8.80215 2.79999 9.0425 3.23945 9.11042 3.72C9.23704 4.68007 9.47187 5.62273 9.81042 6.53C9.94497 6.88792 9.97408 7.27691 9.89433 7.65088C9.81457 8.02485 9.62928 8.36811 9.36042 8.64L8.09042 9.91C9.51398 12.4135 11.5869 14.4864 14.0904 15.91L15.3604 14.64C15.6323 14.3711 15.9756 14.1858 16.3495 14.1061C16.7235 14.0263 17.1125 14.0555 17.4704 14.19C18.3777 14.5286 19.3204 14.7634 20.2804 14.89C20.7662 14.9585 21.2098 15.2032 21.527 15.5775C21.8441 15.9518 22.0126 16.4296 22.0004 16.92Z" class="stroke-brand700 dark:stroke-brand600" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg> </div> <div class="flex-1"> <p class="text-[14px] text-gray400"> Kiritilgan limit daqiqa </p> <p class="text-[20px] text-gray900 dark:text-gray25 font-medium"></p> </div> </div> </div>  </div> <div class="p-[16px] bg-gray100 dark:bg-gray700 rounded-[8px]">  <p class="flex items-center justify-center flex-wrap text-nowrap gap-[8px] text-[28px] leading-[32px] my-[10px] w-[full] text-gray900 dark:text-gray25 font-medium"> 25 000 <span class="lowercase text-[14px] text-[inherit]">So&#39;m/Oyiga</span> </p> <a href="/uz/jismoniy-shaxslarga/uy-telefoni/tariflar/tariflar-telefoniya/limitsiz" class="h-[48px] flex items-center justify-center dark:bg-brand600 bg-brand700 w-full rounded-[8px] text-[16px] text-white font-semibold my-[15px] sm:mt-[25px] sm:mb-[10px]">Ko&#39;proq</a> </div> </div> <div class="absolute top-[100%] left-[50%] translate-x-[-50%] h-[32px] w-[calc(100%_-_100px)] flex items-center justify-center bg-yellow uppercase font-bold text-[16px] text-gray800 rounded-b-[8px] hidden"> Hit </div> </div> </div> </div> <div class="hidden md:block absolute sm:z-[3] right-[46px] xl:right-[0] top-[0] h-[calc(100%_-_10px)] w-[100px] bg-gradient-to-r from-[transparent] to-gray200 dark:to-gray700"></div> </div> </section> <script>
  $(document).ready(function () {
    const selectedCategoryBorder = $("#selectedTariffCategoryBorder");
    const selectedCategoryBg = $("#selectedTariffCategoryBg");
    const tariffCategory = $(".tariff-category");
    const tariffModalUssd = $("#tariffModalUssd");
    const tariffModal = $("#tariffModal");
    const bodyShadow = $("#bodyShadow");

    function changeHeightSwiper(swiper) {
      let maxHeight = 0;
      const slides = $(swiper).find(".swiper-slide");

      slides.each(function () {
        const slideHeight = $(this).height();
        if (slideHeight > maxHeight) maxHeight = slideHeight;
      });

      slides.css("height", `${maxHeight}px`);
    }

    const tariffSwiper = new Swiper("#tariffSwiper", {
      navigation: {
        nextEl: ".tariffSwiperNext",
        prevEl: ".tariffSwiperPrev",
      },
      slidesPerGroup: 1,
      breakpoints: {
        320: {
          slidesPerView: 1,
          spaceBetween: 20,
        },
        375: {
          slidesPerView: 1.1,
          spaceBetween: 20,
        },
        410: {
          slidesPerView: 1.3,
          spaceBetween: 20,
        },
        640: {
          slidesPerView: 1.3,
          spaceBetween: 20,
        },
        768: {
          slidesPerView: 1.5,
          spaceBetween: 20,
        },
        1024: {
          slidesPerView: 2.2,
          spaceBetween: 20,
        },
        1360: {
          slidesPerView: 3.5,
          spaceBetween: 20,
        },
      },
      on: {
        lock: function () {
          $(".tariffSwiperNext").addClass("hidden");
          $(".tariffSwiperPrev").addClass("hidden");
        },
        unlock: function () {
          $(".tariffSwiperNext").removeClass("hidden");
          $(".tariffSwiperPrev").removeClass("hidden");
        },
      },
    });

    $(tariffCategory).on("click", function () {
      const button = $(this);
      const buttonCategory = button.data("category");

      $(tariffCategory)
        .children("div")
        .children("div")
        .addClass("invisible opacity-0");
      $(tariffCategory)
        .children("div")
        .children("div")
        .removeClass("visible opacity-1");
      button.children("div").children("div").removeClass("invisible opacity-0");
      button.children("div").children("div").addClass("visible opacity-1");

      $(`#tariffSwiper .swiper-slide`).each(function () {
        if ($(this).data("category") != buttonCategory)
          $(this).addClass("hidden");
        else $(this).removeClass("hidden");
      });

      tariffSwiper.update();

      //horizontal
      const buttonPosition = button.position();
      const buttonWidth = $(this).outerWidth();
      const buttonLeft = $(this).position().left;

      $(selectedCategoryBg).css({
        width: buttonWidth,
        left: buttonLeft,
      });

      //vertical
      const buttonTop = buttonPosition.top;
      const buttonHeight = button.outerHeight();
      const selectedCategoryHeight = selectedCategoryBorder.outerHeight();
      const newTop = buttonTop + buttonHeight / 2 - selectedCategoryHeight / 2;
      selectedCategoryBorder.css("top", newTop + "px");

      tariffSwiper.update();
    });

    changeHeightSwiper($("#tariffSwiper"));

    tariffCategory[0].click();

    $(".connectTariff").on("click", function () {
      const name = $(this).data("name");
      const lang = $(this).data("lang");
      const code = $(this).data("code");
      const label = $(this).data("label");
      const type = $(this).data("type");
      const tariff = $(this).data("tariff");

      $(bodyShadow).removeClass("invisible opacity-0");

      if (label?.length && code?.length) {
        tariffModalUssd.find(".tariffName").text(`«${name}»`);
        tariffModalUssd.removeClass("invisible opacity-0");
      } else {
        tariffModal.find(".tariffName").text(`«${name}»`);
        tariffModal.find("#tariffSendOrder").data("lang", lang);
        tariffModal.find("#tariffSendOrder").data("tariff", tariff);
        tariffModal.find("#tariffSendOrder").data("type", type);
        tariffModal.removeClass("invisible opacity-0");
      }
    });

    tariffModal.find(".closeModal").on("click", () => {
      $(bodyShadow).addClass("invisible opacity-0");
      tariffModal.addClass("invisible opacity-0");
    });

    tariffModalUssd.find(".closeModal").on("click", () => {
      $(bodyShadow).addClass("invisible opacity-0");
      tariffModal.addClass("invisible opacity-0");
    });
  });
